#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

python3 - <<'PY'
from pathlib import Path
import base64

html_template = Path('musicpad-html.html')
engine_file = Path('musicpad.js')
soundfont_file = Path('A320U.sf2')
output_file = Path('musicpad.html')

template = html_template.read_text()
engine = engine_file.read_text()
soundfont = base64.encodebytes(soundfont_file.read_bytes()).decode('ascii')

engine_block = f'  <script>\n{engine}\n  </script>'
soundfont_block = f'  <script id="soundFontA320U" type="application/octet-stream">\n{soundfont}</script>'

missing = [name for name in ('<!-- MUSICPAD_JS -->', '<!-- SOUNDFONT_A320U -->') if name not in template]
if missing:
    raise SystemExit(f'missing placeholder(s): {", ".join(missing)}')

output = template.replace('  <!-- MUSICPAD_JS -->', engine_block, 1)
output = output.replace('  <!-- SOUNDFONT_A320U -->', soundfont_block, 1)
output_file.write_text(output)
print(f'wrote {output_file}')
PY
