#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

template="musicpad-html.html"
docs="musicpad-docs.html"
engine="musicpad.js"
songlist="songlist.js"
soundfont="A320U.sf2"
output="musicpad.html"

for file in "$template" "$docs" "$engine" "$songlist" "$soundfont"; do
  if [[ ! -f "$file" ]]; then
    printf 'missing required file: %s\n' "$file" >&2
    exit 1
  fi
done

tmp="$(mktemp "${output}.tmp.XXXXXX")"
trap 'rm -f "$tmp"' EXIT

found_docs=0
found_engine=0
found_songlist=0
found_soundfont=0

while IFS= read -r line || [[ -n "$line" ]]; do
  case "$line" in
    '    <!-- MUSICPAD_DOCS -->')
      cat "$docs"
      found_docs=1
      ;;
    '  <!-- MUSICPAD_JS -->')
      printf '  <script>\n'
      cat "$engine"
      printf '\n  </script>\n'
      found_engine=1
      ;;
    '  <!-- SONGLIST_JS -->')
      printf '  <script>\n'
      cat "$songlist"
      printf '\n  </script>\n'
      found_songlist=1
      ;;
    '  <!-- SOUNDFONT_A320U -->')
      printf '  <script id="soundFontA320U" type="application/octet-stream">\n'
      base64 "$soundfont"
      printf '</script>\n'
      found_soundfont=1
      ;;
    *)
      printf '%s\n' "$line"
      ;;
  esac
done < "$template" > "$tmp"

missing=()
[[ "$found_docs" -eq 1 ]] || missing+=(MUSICPAD_DOCS)
[[ "$found_engine" -eq 1 ]] || missing+=(MUSICPAD_JS)
[[ "$found_songlist" -eq 1 ]] || missing+=(SONGLIST_JS)
[[ "$found_soundfont" -eq 1 ]] || missing+=(SOUNDFONT_A320U)

if [[ "${#missing[@]}" -gt 0 ]]; then
  printf 'missing placeholder(s): %s\n' "${missing[*]}" >&2
  exit 1
fi

mv "$tmp" "$output"
trap - EXIT
printf 'wrote %s\n' "$output"
